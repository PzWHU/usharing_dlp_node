module_name: "aggregator"
is_pub_result: true
# get pvb result
operators {
  name: "GetCameraObjects_PostProcess"
  type: "ProducerConsumerOP"
  top: "GetAggInput"
  producer_consumer_param {
    is_producer: false
    data_name: "nv_cameras"
    set_op_name: "SetCameraObjects_PostProcess"
    is_get_camera_object: true
  }
}
# get radar from swc
operators {
    name: "GetAggInput"
    type: "DataInputConsumerOP"
    top: "aggregator_prepare_op"
    data_input_consumer_param {
        set_op_name: "SapDataInput"
        is_producer: false
        radar_name: 
        ["front_radar",
          "front_left_radar",
          "front_right_radar",
          "rear_radar",
          "rear_left_radar",
          "rear_right_radar"]
        is_radar_object_input: true
        radar_config_param {
          radar_name: "front_radar"
          use_radar_obj_yaw_compensate: true
          radar_obj_compensate_timestamp_gap: 200
        }
        radar_config_param {
          radar_name: "front_left_radar"
          use_radar_obj_yaw_compensate: true
          radar_obj_compensate_timestamp_gap: 70
        }
        radar_config_param {
          radar_name: "front_right_radar"
          use_radar_obj_yaw_compensate: true
          radar_obj_compensate_timestamp_gap: 70
        }
        radar_config_param {
          radar_name: "rear_left_radar"
          use_radar_obj_yaw_compensate: true
          radar_obj_compensate_timestamp_gap: 200
        }
        radar_config_param {
          radar_name: "rear_right_radar"
          use_radar_obj_yaw_compensate: true
          radar_obj_compensate_timestamp_gap: 200
        }
        radar_config_param {
          radar_name: "rear_radar"
          use_radar_obj_yaw_compensate: true
          radar_obj_compensate_timestamp_gap: 70
        }
    }
}


operators {
  name: "aggregator_prepare_op"
  type: "AggregatorPrepareOP"
  top: "start_op"
  root_path: ""
  prepare_param {
    name: "nVnRnL_pvb-4-0-0"
    num_workers: 1
    root_path: ""
    launch_mode: CAMERA_LIDAR_RADAR
    keep_association_info_param {
      keep_camera_association_max_threshold_second: 0.85
      keep_radar_association_max_threshold_second: 0.85
      keep_lidar_association_max_threshold_second: 0.85
    }
    main_sensor_names: [
      "front_radar",
      "center_camera_fov120"
    ]
    required_sensor_names: [
      "front_radar",
      "front_left_radar",
      "front_right_radar",
      "rear_left_radar",
      "rear_right_radar",
      "rear_radar",
      "nv_cameras",
      "center_camera_fov30",
      "center_camera_fov120",
      "right_front_camera",
      "right_rear_camera",
      "left_front_camera",
      "left_rear_camera",
      "rear_camera"
    ]
  }
}
operators {
  name: "start_op"
  type: "StartOP"
  top: "CalibrationManagerOp_1"
}
##################################### Calibration #####################################
operators {
  name: "CalibrationManagerOp_1"
  type: "AggCalibrationManagerOP"
  # top: "LidarUnknownObstacleProcessOP_1"
  top: "CameraRadarVRUPreprocessOP_Front_Camera"
  # top: "CameraRadarVRUPreprocessOP_FOV30_PED"
  # top: "LidarObjectPreprocessOP_FrontLidar"
  calibration_param {
    vehicle_param {
      sensor_config_folder: "/opt/usr/cfg/st_calib/conf/"
    }
    inter_camera_param {
        # camera_mapping_param {
        #   src_camera_name: "center_camera_fov120"
        #   dst_camera_name: "center_camera_fov30"
        #   is_matching_reversed: true
        # }
        # camera_mapping_param {
        #   src_camera_name: "center_camera_fov30"
        #   dst_camera_name: "center_camera_fov120"
        #   is_matching_reversed: true
        # }
        camera_mapping_param {
          src_camera_name: "right_front_camera"
          dst_camera_name: "center_camera_fov120"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "center_camera_fov120"
          dst_camera_name: "right_front_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "left_front_camera"
          dst_camera_name: "center_camera_fov120"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "center_camera_fov120"
          dst_camera_name: "left_front_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "left_rear_camera"
          dst_camera_name: "rear_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "rear_camera"
          dst_camera_name: "left_rear_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "right_rear_camera"
          dst_camera_name: "rear_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "rear_camera"
          dst_camera_name: "right_rear_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "right_rear_camera"
          dst_camera_name: "right_front_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "right_front_camera"
          dst_camera_name: "right_rear_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "left_rear_camera"
          dst_camera_name: "left_front_camera"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "left_front_camera"
          dst_camera_name: "left_rear_camera"
          is_matching_reversed: true
        }
        # camera_mapping_param {
        #   src_camera_name: "center_camera_fov30"
        #   dst_camera_name: "ground_projection"
        #   is_matching_reversed: true
        # }
        camera_mapping_param {
          src_camera_name: "center_camera_fov120"
          dst_camera_name: "ground_projection"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "left_front_camera"
          dst_camera_name: "ground_projection"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "right_front_camera"
          dst_camera_name: "ground_projection"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "left_rear_camera"
          dst_camera_name: "ground_projection"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "right_rear_camera"
          dst_camera_name: "ground_projection"
          is_matching_reversed: true
        }
        camera_mapping_param {
          src_camera_name: "rear_camera"
          dst_camera_name: "ground_projection"
          is_matching_reversed: true
        }
    }
    single_camera_param {
      # considered_camera_name: "center_camera_fov30"
      considered_camera_name: "center_camera_fov120"
      considered_camera_name: "rear_camera"
      considered_camera_name: "left_front_camera"
      considered_camera_name: "right_front_camera"
      considered_camera_name: "left_rear_camera"
      considered_camera_name: "right_rear_camera"
    }
    sensor_projection_param {
      car_center_name: "car_center"
      ground_projection_name: "ground_projection"
      main_lidar_name: "front_lidar"
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "front_lidar"
      }
      # pair_sensor_param {
      #   src_sensor_name: "car_center"
      #   dst_sensor_name: "center_camera_fov30"
      # }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "center_camera_fov120"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "rear_camera"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "left_front_camera"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "left_rear_camera"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "right_front_camera"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "right_rear_camera"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "front_radar"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "rear_radar"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "front_left_radar"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "front_right_radar"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "rear_left_radar"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "rear_right_radar"
      }
      pair_sensor_param {
        src_sensor_name: "car_center"
        dst_sensor_name: "ground_projection"
      }
    }
    valid_region_param {
      sensor_name: "front_radar"
      min_theta: -1.2217
      max_theta: 1.2217
      min_r: 0
      max_r: 200
      p_max: 1.0
      m_r: 0.2
      m_phi: 0.1
    }
    # valid_region_param {
    #   sensor_name: "center_camera_fov30"
    #   min_theta: -1.2217
    #   max_theta: 1.2217
    #   min_r: 0
    #   max_r: 200
    #   p_max: 1.0
    #   m_r: 0.2
    #   m_phi: 0.1
    # }
    verify_extrinsic: true
  }
}
