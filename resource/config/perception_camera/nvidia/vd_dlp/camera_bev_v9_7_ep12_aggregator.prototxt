operators {
  name: "GeneralTimeAlignSensorObjectAssociatorOP_2"
  type: "GeneralTimeAlignSensorObjectAssociatorOP"
  top: "GeneralTimeAlignSensorObjectAssociatorOP_2_PED_CEN120"
  track_object_association_param {
    src_sensor_names: [
      "center_camera_fov120",
      "left_front_camera",
      "right_front_camera"
    ]
    delete_object_from_group: false
    update_mode: WITHIN_CURRENT_SENSOR
    process_label: [ "VEHICLE", "VEHICLE_BUS"]
    object_match_param {
      enabled_label_checking: false
      valid_similarity_threshold: 0.001
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: 0.0
        scale_factor: 1
        similarity {
            similarity_type: MOTION_VAR_GATED_CENTER_DISTANCE
            similarity_weight: 1.0
            similarity_usage: SIM_ADD
        }
      }
    }
  }
}
