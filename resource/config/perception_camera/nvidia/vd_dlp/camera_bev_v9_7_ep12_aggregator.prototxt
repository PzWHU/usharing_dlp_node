# timealign for side radar with cross
operators {
  name: "TimeAlignSideRadarCycObjectAssociatorOP_FrontSide"
  type: "TimeAlignSideRadarCycObjectAssociatorOP"
  top: "TimeAlignVRUObjectAssociatorOP_SideMainSensor"
  track_object_association_param {
    src_sensor_names: [
      "front_left_radar",
      "front_right_radar",
      "front_radar"
    ]
    process_label: [
      "PEDESTRIAN",
      "BIKE"
    ]
    object_match_param {
      process_label: [ "PEDESTRIAN", "BIKE"]
      valid_similarity_threshold_moving: 0.001
      valid_similarity_threshold_still: 0.005
      valid_similarity_threshold: 0.3
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: false
            long_uncertainty_ratio: 0.3
            checking_sensor_fov_overlap: false
            fov_expand_ratio: 2
            distance_threshold: 20
        }
      }
    }
  }
}
# timealign for all side sensors
operators {
  name: "TimeAlignVRUObjectAssociatorOP_SideMainSensor"
  type: "TimeAlignVRUObjectAssociatorOP"
  top: "Camera_IDBasedObjectGroupAssociatorOP_1"
  top: "Camera_IDBasedObjectGroupAssociatorOP_2"
  # top: "LidarIDBasedSimilarityAssociatorOP_1"
  # top: "TimeAlignVRUObjectAssociatorOP_SideRadar"
  track_object_association_param {
    sensor_process_info {
      sensor_name: "left_front_camera"
      min_fov_angle_degree: 15
      max_fov_angle_degree: 110
      max_distance: 40.0
    }
    sensor_process_info {
      sensor_name: "right_front_camera"
      min_fov_angle_degree: -110
      max_fov_angle_degree: -15
      max_distance: 40.0
    }
    sensor_process_info {
      sensor_name: "left_rear_camera"
      min_fov_angle_degree: 70
      max_fov_angle_degree: 180
      max_distance: 40.0
    }
    sensor_process_info {
      sensor_name: "right_rear_camera"
      min_fov_angle_degree: -180
      max_fov_angle_degree: -70
      max_distance: 40.0
    }
    # sensor_process_info {
    #   sensor_name: "rear_camera"
    #   min_fov_angle_degree: -180
    #   max_fov_angle_degree: -160
    #   max_distance: 60.0
    # }
    # sensor_process_info {
    #   sensor_name: "rear_camera"
    #   min_fov_angle_degree: 160
    #   max_fov_angle_degree: 180
    #   max_distance: 60.0
    # }
    # sensor_process_info {
    #   sensor_name: "front_lidar"
    #   min_fov_angle_degree: -150
    #   max_fov_angle_degree: 150
    #   max_distance: 70.0
    # }
    process_label: [
      "PEDESTRIAN",
      "BIKE"
    ]
    object_match_param {
      enabled_label_checking: false
      valid_similarity_threshold: 0.001
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: 0.0
        scale_factor: 1
        similarity {
            similarity_type: VRU_MOTION_VAR_GATED_CENTER_DISTANCE
            similarity_weight: 1.0
            similarity_usage: SIM_ADD
        }
      }
    }
  }
}
