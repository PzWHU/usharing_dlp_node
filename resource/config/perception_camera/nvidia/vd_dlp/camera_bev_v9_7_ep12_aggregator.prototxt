  top: "RadarAssociator_3"
  top: "RadarAssociator_4"
  top: "RadarAssociator_5"
  top: "RadarAssociator_6"
  sensor_object_preprocess_param {
    # src_sensor_name: "center_camera_fov30"
    conflict_sensor_names: ["center_camera_fov120", "left_rear_camera",
                            "center_camera_fov120", "right_rear_camera",
                            "center_camera_fov120", "rear_camera",
                            "left_front_camera", "rear_camera",
                            "left_front_camera", "right_front_camera",
                            "left_front_camera", "right_rear_camera",
                            "left_rear_camera", "right_front_camera",
                            "left_rear_camera", "right_rear_camera",
                            "right_front_camera", "rear_camera"
                          ]
    object_match_param {
      valid_similarity_threshold: 0.01
      enabled_label_checking: false
      process_label: [
          "VEHICLE",
          "VEHICLE_BUS",
          "PEDESTRIAN",
          "BIKE"
        ]
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: CENTER_DISTANCE
            similarity_weight: 1.0
            similarity_usage: SIM_ADD
        }
      }
    }
  }
}

operators {
  name: "RadarAssociator_BUS1"
  type: "CameraRadarObjectBusAssociatorOP"
  top: "RadarAssociator_CYC1"
  object_motion_param {
    process_class_label: "VEHICLE_BUS"
  }
  track_object_association_param {
    src_sensor_name: "front_radar"
    update_mode: ASSIGN_SENSOR_OBJECT_GROUP
    stability_lateral_camera_names: [
        # "center_camera_fov30",
        "center_camera_fov120",
        "rear_camera"
    ]
    camera_bbox_checking_lateral_scale: 1.5
    object_on_adjacent_lane_lateral_threshold: 1
    bus_tracker_min_lateral_distance: -20
    bus_tracker_max_lateral_distance: 20
    bus_tracker_min_longitude_distance: -100
    bus_tracker_max_longitude_distance: 150
    min_fov_angle: 0
    max_fov_angle: 181
    object_match_param {
      near_expand_length: 1
      near_expand_witdh: 1
      using_overlap_check: true
      valid_similarity_threshold: 0.01
      valid_similarity_threshold_moving: 0.15
      valid_similarity_threshold_still: 0.2
      associated_tracker_similarity_threshold_moving: 0.1
      associated_tracker_similarity_threshold_still: 0.9
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver"
        match_capacity: 1
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
          similarity_type: POINT_PLANE_DISTANCE
          similarity_usage: SIM_ADD
          similarity_weight: 1.0
          scale_factor_unit: 1
          length_expand_ratio: 3
          width_expand_ratio: 2
          tracklet_velocity_threshold: 2.5
          using_nearest_face: false
          filter_association_using_velocity_direction: true
          similarity_filter_velocity_direction_threshold: -20
          filter_association_using_velocity_weighted: true
          similarity_filter_velocity_weighted_threshold: 0.001
          variable_length_expand_ratio: true
          variable_width_expand_ratio: true
          x_weight: 0.5
          y_weight: 1.5
          velocity_threshold: 8.0
          checking_sensor_fov_overlap: true
        }
      }
    }
  }
}

