############################## Inter-Camera-Preprocess #################################
# preprocessing
operators {
  name: "InterCameraObjectDepthPreprocessOP_1"
  type: "InterCameraObjectDepthPreprocessOP"
  top: "CameraRadarObjectPreprocessByProjectOP_1"
  # top: "LidarRadarObjectPreprocessOP_1"
  # top: "LidarRadarObjectPreprocessOP_2"
  # top: "LidarRadarObjectPreprocessOP_3"
  runnning_mode: [
    CAMERA_ONLY,
    CAMERA_RADAR,
    CAMERA_LIDAR_RADAR,
    CAMERA_LIDAR,
    LIDAR_RADAR,
    LIDAR_ONLY
  ]
  sensor_object_preprocess_param {
    src_sensor_names: [
      "center_camera_fov120",
      "rear_camera",
      "left_front_camera",
      "right_front_camera",
      "left_rear_camera",
      "right_rear_camera"]
    dst_sensor_name: ""
    object_match_param {
      process_label: [ "VEHICLE"]
      valid_similarity_threshold: 0.01
      var_x_threshold: 70
      var_y_threshold: 30
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: CENTER_DISTANCE_WITH_LATERAL_CHECKING
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            width_expand_ratio: 0.5
        }
        # similarity {
        #   similarity_type: REID_SCORE
        #   similarity_usage: SIM_FILTER
        #   similarity_filter_threshold: 0.1
        # }
      }
    }
  }
}

operators {
  name: "InterCameraObjectDepthPreprocessOP_BUS1"
  type: "InterCameraObjectDepthPreprocessOP"
  top: "CameraRadarObjectPreprocessByProjectOP_1"
  # top: "InterCameraObjectDepthPreprocessOP_BUS7"
  # top: "LidarRadarObjectPreprocessOP_1"
  # top: "LidarRadarObjectPreprocessOP_2"
  # top: "LidarRadarObjectPreprocessOP_3"
  runnning_mode: [
    CAMERA_ONLY,
    CAMERA_RADAR,
    CAMERA_LIDAR_RADAR,
    CAMERA_LIDAR,
    LIDAR_RADAR,
    LIDAR_ONLY
  ]
  sensor_object_preprocess_param {
    src_sensor_names: [
      "center_camera_fov120", 
      "rear_camera",
      "left_front_camera",
      "right_front_camera",
      "left_rear_camera",
      "right_rear_camera"]
    dst_sensor_name: ""
    object_match_param {
      process_label: [ "VEHICLE_BUS" ]
      stability_match_label: [ "VEHICLE_BUS" ]
      valid_similarity_threshold: 0.01
      var_x_threshold: 70
      var_y_threshold: 30
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: CENTER_DISTANCE_WITH_LATERAL_CHECKING
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            lateral_distance_width_ratio: 0.7
            width_expand_ratio: 0.5
        }
        # similarity {
        #   similarity_type: REID_SCORE
        #   similarity_usage: SIM_FILTER
        #   similarity_filter_threshold: 0.1
        # }
      }
    }
  }
}

