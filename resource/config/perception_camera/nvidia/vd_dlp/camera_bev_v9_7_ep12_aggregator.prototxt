# object manager
operators {
  name: "ObjectManagerOP_1"
  type: "TraditionalGeneralObjectManagerOP"
  top: "IMMMotionBufferPredictorOP_1_INIT"
  top: "IMMMotionBufferPredictorOP_2_INIT"
  top: "IMMMotionBufferPredictorOP_3_INIT"
  top: "IMMMotionBufferPredictorOP_4_INIT"
  object_manager_param {
    var_x_threshold: 10
    var_y_threshold: 2
    min_velocity_to_direction: 3
    min_visible_point: 1
    x_expdand_pixel: -50
    y_expdand_pixel: -50
    project_sensor_names: [
        # "center_camera_fov30",
        "center_camera_fov120",
        "rear_camera",
        "left_front_camera",
        "right_front_camera",
        "left_rear_camera",
        "right_rear_camera"
    ]
    object_create_param {
      min_hits_init: 2
      min_neighbor_size: 1
      radar_cluster_long_position_theshold_bus: 5
      radar_cluster_lat_position_theshold_bus: 1
      radar_cluster_position_sum_theshold_bus: 6
      radar_cluster_long_velocity_theshold_bus: 2
      radar_cluster_lat_velocity_theshold_bus: 0.8
      radar_cluster_velocity_sum_theshold_bus: 3
      radar_cluster_long_position_theshold_veh: 3
      radar_cluster_lat_position_theshold_veh: 1
      radar_cluster_position_sum_theshold_veh: 4
      radar_cluster_long_velocity_theshold_veh: 2
      radar_cluster_lat_velocity_theshold_veh: 0.8
      radar_cluster_velocity_sum_theshold_veh: 3
      camera_radar_velocity_long_diff: 4
      camera_radar_velocity_lat_diff: 1.8
      angle_diff_threshold: 10
      velocity_norm_diff_threshold: 5
      associate_radar_number: 1
      near_bus_min_lateral: 0 
      near_bus_max_lateral: 0
      near_bus_min_long_range: 0
      near_bus_max_long_range: 0
      min_radar_measure: 1
      far_bus_long_distance_threshold: 65
      near_bus_long_distance_threshold: 40
      bus_lateral_distance_threshold: 15
      near_distance_radar_number: 1
      medium_distance_radar_number: 1
      far_distance_radar_number: 0
      radar_only_created_min_velocity: 6.0
      radar_only_created_min_fov: -180
      radar_only_created_max_fov: 180
      radar_only_created_min_lateral: -20
      radar_only_created_max_lateral: 20
      # radar_only_created_min_long_abs: 60
      # radar_only_created_max_long_abs: 200
      radar_only_created_min_long_front: 4
      radar_only_created_max_long_front: 80
      radar_only_created_min_long_rear: -200
      radar_only_created_max_long_rear: -2
      fov120_creat_position_theshold_veh: 240
      fov120_creat_position_theshold_vru: 90
      init_fov120_need_other_sensor_confirm: false
    }
    object_delete_param {
      # blind zoon
      blind_zone_min_time_s: 2
      blind_zone_min_fov: 90
      blind_zone_max_fov: 150
      blind_zone_min_lateral: -10
      blind_zone_max_lateral: 10
      blind_zone_min_long: -20
      blind_zone_max_long: 20
      # general zoon
      min_time_s_since_update: 0.5
      initial_min_time_s_since_update: 0.15
      min_time_s_since_camera_update: 0.8
      delete_cross_road_min_time_s_since_update: 0.15
      delete_cross_road_velocity_threshold: 5
      min_lateral_distance: -15
      max_lateral_distance: 15
      min_longitude_distance: -20
      max_longitude_distance: 20
      hit_number: 100
      nearest_object_min_time_s_since_update: 1.0
      create_bus_tracker_min_lateral_distance: -10
      create_bus_tracker_max_lateral_distance: 10
      create_bus_tracker_min_longitude_distance: -15
      create_bus_tracker_max_longitude_distance: 15
      create_veh_tracker_min_lateral_distance: -10
      create_veh_tracker_max_lateral_distance: 10
      create_veh_tracker_min_longitude_distance: -1
      create_veh_tracker_max_longitude_distance: 1
      direction_stability_threshold: 5
      max_angle_diff: 15
      delete_radar_only_tracker_distance: 40
      filter_lateral_fp_min_long: 0
      filter_lateral_fp_max_long: 0
      filter_lateral_fp_min_lateral: 0
      filter_lateral_fp_max_lateral: 0
      filter_lateral_fp_min_fov: 0
      filter_lateral_fp_max_fov: 0
      filter_trk_distance_threshold: 50
    }
  }
}
#################################################################
# predictor init
operators {
  name: "IMMMotionBufferPredictorOP_1_INIT"
  type: "IMMMotionBufferPredictorOP"
  # top: "CameraTrackerMergeOP_1"
  # # top: "CameraTrackerMergeOP_2"
  # top: "CameraTrackerMergeOP_3"
  # # CameraTrackerMergeOP_2
  # top: "CameraTrackerMergeOP_VEH1"
  # top: "CameraTrackerMergeOP_VEH_BUS1"
  top: "TerminalOP_final"
  object_motion_param {
    opt_config_for_initial_object: true
    process_class_label: "VEHICLE"
    is_optimze_lidar_radar_bias: false
    is_optimze_camera_radar_bias: false
    is_optimze_yaw: false
    is_limit_speed: true
    rectify_object_motion_param {
      is_limit_speed: true
      is_rectify_direction: true
      min_veh_vel: 2.5
      min_velbus_vel: 2.5
      min_bike_vel: 0.1
      smooth_acceleration: false
      smooth_acceleration_window: 5
      smooth_acceleration_scale: 0.5
      smooth_velocity: true
      smooth_velocity_scale: 0.7
      static_smooth_velocity_scale: 0.9
      smooth_position: false
      decay_position: true
      smooth_position_scale: 0.5
      min_camera_only_strike_num: 0
    }
    output_position_constrain_param {
      enable: true
      vehicle_lateral_side_distance_threshold: 1.7
      vehicle_long_side_distance_threshold: 3.5
      bus_lateral_side_distance_threshold: 3.0
      bus_long_side_distance_threshold: 3.5
    }
    estimator_param {
      estimator_core_name: "IMMEstimatorCore"
      is_use_unstable_obs: false
      unstable_state_diff: 15.0
      unstable_distance: 60.0
      allow_unstable_hits: 5
      imm_tracker_param {
        model_prob: [0.5, 0.5]
        transfer_prob: [0.9, 0.1, 0.1, 0.9]
        imm_filter_name: "IMMFilter"
        depth_tracker_param {
          motion_model_type: "CVProcessModel"
          filter_type: "ExtendedKalmanFilter"
          measure_types: ["camera"]
          is_add_process_noise_bias: true
          process_noise_bias: [0.04,0.005,0.01, 0.005,0,0] # x,y,vx,vy,ax,ay
          state_dim: 8
          measure_dims: [2]
          measure_dim: 2
          measure_type: "camera"
          process_cov_base_p: 0.1
          cv_process_noise_cov_base_q: 0.1
          ca_process_noise_cov_base_q: 0.1
          ctrv_process_noise_vel_cov_base_q: 0.3
          ctrv_process_noise_yaw_cov_base_q: 0.1
          cv_process_noise_yaw_cov_base_q: 0.1
          cp_process_noise_yaw_cov_base_q: 0.1
          ca_process_noise_yaw_cov_base_q: 0.1
          lidar_measurement_noise_cov_base_r: 0.01
          lidar_measurement_velocity_noise_cov_x_base_r: 0.01
          lidar_measurement_velocity_noise_cov_y_base_r: 0.5
          camera_acceleration_measurement_x_noise_cov_base_r: 0.01
          radar_measurement_noise_cov_base: 0.2
          camera_measurement_noise_cov_base_r: 2.1
          camera_position_measurement_x_noise_cov_base_r: 0.8
          camera_position_measurement_y_noise_cov_base_r: 0.04
          camera_velocity_measurement_x_noise_cov_base_r: 0.8
          camera_velocity_measurement_y_noise_cov_base_r: 0.1
          ct_process_noise_cov_base_q: 0.01
          ct_process_noise_yaw_cov_base_q: 0.01
          yaw_rate_threshold: 0.15
          acceleration_x_threshold: 10
          acceleration_y_threshold: 5
          is_optimze_yaw: false
          tracker_core_param {
            largest_time_gap: 6
            prograte_time_gap: 5
            clear_old_than: 10
            add_newstate_time_gap: 0.002
          }
        }
        # depth_tracker_param {
        #   motion_model_type: "CTProcessModel"
        #   filter_type: "ExtendedKalmanFilter"
        #   measure_types: ["camera"]
        #   state_dim: 8
        #   measure_dims: [2]
        #   measure_dim: 2
        #   measure_type: "camera"
        #   process_cov_base_p: 0.1
        #   cv_process_noise_cov_base_q: 0.1
        #   ca_process_noise_cov_base_q: 0.1
        #   ctrv_process_noise_vel_cov_base_q: 0.3
        #   ctrv_process_noise_yaw_cov_base_q: 0.1
        #   cv_process_noise_yaw_cov_base_q: 0.1
        #   cp_process_noise_yaw_cov_base_q: 0.1
        #   ca_process_noise_yaw_cov_base_q: 0.1
        #   lidar_measurement_noise_cov_base_r: 0.01
        #   lidar_measurement_velocity_noise_cov_x_base_r: 0.01
        #   lidar_measurement_velocity_noise_cov_y_base_r: 0.5
        #   camera_acceleration_measurement_x_noise_cov_base_r: 0.01
        #   radar_measurement_noise_cov_base: 0.2
        #   camera_measurement_noise_cov_base_r: 3.1
        #   camera_position_measurement_x_noise_cov_base_r: 0.8
        #   camera_position_measurement_y_noise_cov_base_r: 0.04
        #   camera_velocity_measurement_x_noise_cov_base_r: 0.8
        #   camera_velocity_measurement_y_noise_cov_base_r: 0.1
        #   ct_process_noise_cov_base_q: 0.01
        #   ct_process_noise_yaw_cov_base_q: 0.01
        #   yaw_rate_threshold: 0.15
        #   acceleration_x_threshold: 5
        #   acceleration_y_threshold: 5
        #   is_optimze_yaw: false
        #   tracker_core_param {
        #     largest_time_gap: 6
        #     prograte_time_gap: 5
        #     clear_old_than: 10
        #     add_newstate_time_gap: 0.002
        #   }
        # }
        depth_tracker_param {
          motion_model_type: "CAProcessModel"
          filter_type: "ExtendedKalmanFilter"
          measure_types: ["camera"]
          state_dim: 8
          measure_dims: [2]
          measure_dim: 2
          measure_type: "camera"
          process_cov_base_p: 0.1
          is_add_process_noise_bias: true
          process_noise_bias: [0.04,0.005,0.005,0,0.01,0] # x,y,vx,vy,ax,ay
          cv_process_noise_cov_base_q: 0.1
          ca_process_noise_cov_base_q: 0.1
          ctrv_process_noise_vel_cov_base_q: 0.3
          ctrv_process_noise_yaw_cov_base_q: 0.1
          cv_process_noise_yaw_cov_base_q: 0.1
          cp_process_noise_yaw_cov_base_q: 0.1
          ca_process_noise_yaw_cov_base_q: 0.1
          lidar_measurement_noise_cov_base_r: 0.01
          lidar_measurement_velocity_noise_cov_x_base_r: 0.01
          lidar_measurement_velocity_noise_cov_y_base_r: 0.5
          camera_acceleration_measurement_x_noise_cov_base_r: 0.01
          radar_measurement_noise_cov_base: 0.2
          camera_measurement_noise_cov_base_r: 3.0
          camera_position_measurement_x_noise_cov_base_r: 0.8
          camera_position_measurement_y_noise_cov_base_r: 0.04
          camera_velocity_measurement_x_noise_cov_base_r: 0.8
          camera_velocity_measurement_y_noise_cov_base_r: 0.1
          ct_process_noise_cov_base_q: 0.01
          ct_process_noise_yaw_cov_base_q: 0.01
          yaw_rate_threshold: 0.15
          acceleration_x_threshold: 10
          acceleration_y_threshold: 5
          is_optimze_yaw: false
          tracker_core_param {
            largest_time_gap: 6
            prograte_time_gap: 5
            clear_old_than: 10
            add_newstate_time_gap: 0.002
          }
        }
      }
    }
  }
}
operators {
  name: "IMMMotionBufferPredictorOP_2_INIT"
  type: "IMMMotionBufferPredictorOP"
  # top: "CameraTrackerMergeOP_1"
  # # top: "CameraTrackerMergeOP_2"
  # top: "CameraTrackerMergeOP_3"
  # # CameraTrackerMergeOP_2
  # top: "CameraTrackerMergeOP_VEH1"
  # top: "CameraTrackerMergeOP_VEH_BUS1"
  top: "TerminalOP_final"
  object_motion_param {
    opt_config_for_initial_object: true
    process_class_label: "PEDESTRIAN"
    is_optimze_lidar_radar_bias: false
    is_optimze_camera_radar_bias: false
    is_optimze_yaw: false
    main_sensor_name: "front_lidar"
    rectify_object_motion_param {
      is_limit_speed: true
      is_rectify_direction: true
      min_veh_vel: 0.3
      min_velbus_vel: 0.3
      min_bike_vel: 0.1
      smooth_acceleration: false
      smooth_acceleration_window: 5
      smooth_acceleration_scale: 0.5
      smooth_velocity: true
      smooth_velocity_scale: 0.7
      static_smooth_velocity_scale: 0.9
      smooth_position: false
      smooth_position_scale: 0.5
      min_camera_only_strike_num: 0
    }
    estimator_param {
      estimator_core_name: "IMMEstimatorCore"
      imm_tracker_param {
        model_prob: [1.0]
        transfer_prob: [1.0]
        imm_filter_name: "IMMFilter"
        depth_tracker_param {
          motion_model_type: "CVProcessModel"
          filter_type: "ExtendedKalmanFilter"
          is_add_process_noise_bias: true
          process_noise_bias: [0.04,0.005,0.002, 0.005,0,0] # x,y,vx,vy,ax,ay
          cp_process_noise_cov_base_q: 100
          cv_process_noise_cov_base_q: 0.1
          ca_process_noise_cov_base_q: 0.1
          ct_process_noise_cov_base_q: 1.3
          cp_process_noise_yaw_cov_base_q: 0.1
          cv_process_noise_yaw_cov_base_q: 0.1
          ca_process_noise_yaw_cov_base_q: 0.1
          ct_process_noise_yaw_cov_base_q: 0.1
          lidar_measurement_noise_cov_base_r: 0.001
          lidar_measurement_velocity_noise_cov_x_base_r: 0.01
          lidar_measurement_velocity_noise_cov_y_base_r: 0.05
          camera_acceleration_measurement_x_noise_cov_base_r: 0.01
          camera_position_measurement_x_noise_cov_base_r: 0.8
          camera_position_measurement_y_noise_cov_base_r: 0.04
          camera_velocity_measurement_x_noise_cov_base_r: 0.8
          camera_velocity_measurement_y_noise_cov_base_r: 0.02
          camera_measurement_noise_cov_base_r: 3.1
          radar_measurement_noise_cov_base: 0.1
          is_radar_position_measurement_valid: false
          yaw_rate_threshold: 0.1
          acceleration_x_threshold: 5.0
          acceleration_y_threshold: 5.0
          velocity_x_threshold: 60.0
          velocity_y_threshold: 60.0
          tracker_core_param {
            largest_time_gap: 3
            prograte_time_gap: 5
            clear_old_than: 10
            add_newstate_time_gap: 0.002
          }
        }
      }
    }
  }
}
