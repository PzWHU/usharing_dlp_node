#   top: "InterCameraObjectDepthPreprocessOP_6"
#   top: "InterCameraObjectDepthPreprocessOP_BUS6"
#   top: "InterCameraObjectDepthPreprocessOP_PED6"
#   top: "InterCameraObjectDepthPreprocessOP_BIKE6"
  measurement_stability_param {
    process_sensor_name: [
        # "center_camera_fov30",
        "center_camera_fov120",
        "rear_camera",
        "left_front_camera",
        "right_front_camera",
        "left_rear_camera",
        "right_rear_camera"
    ]
    process_label: [
        "VEHICLE_BUS"
    ]
    reset_window_time: 2
    stable_measure_decay_rate: 0.5
    delete_window_time: 5
    var_x_threshold: 8
    var_y_threshold: 3.5
    direction_threshold: 15
    moving_direction_interval_time: 1
  }
}

operators {
  name: "EstimateCameraMeasurementStabilityOP_VEH1"
  type: "EstimateCameraMeasurementStabilityOP"
  # top: "OfflineEstimateCameraNoiseParamsOp_1"
  top: "InterCameraObjectDepthPreprocessOP_1"
  top: "InterCameraObjectDepthPreprocessOP_BUS1"
  top: "InterCameraObjectDepthPreprocessOP_PED1"
  top: "InterCameraObjectDepthPreprocessOP_BIKE1"
#   top: "InterCameraObjectDepthPreprocessOP_2"
#   top: "InterCameraObjectDepthPreprocessOP_BUS2"
#   top: "InterCameraObjectDepthPreprocessOP_3"
#   top: "InterCameraObjectDepthPreprocessOP_BUS3"
#   top: "InterCameraObjectDepthPreprocessOP_PED3"
#   top: "InterCameraObjectDepthPreprocessOP_BIKE3"
#   top: "InterCameraObjectDepthPreprocessOP_4"
#   top: "InterCameraObjectDepthPreprocessOP_BUS4"
#   top: "InterCameraObjectDepthPreprocessOP_5"
#   top: "InterCameraObjectDepthPreprocessOP_BUS5"
#   top: "InterCameraObjectDepthPreprocessOP_PED5"
#   top: "InterCameraObjectDepthPreprocessOP_BIKE5"
#   top: "InterCameraObjectDepthPreprocessOP_6"
#   top: "InterCameraObjectDepthPreprocessOP_BUS6"
#   top: "InterCameraObjectDepthPreprocessOP_PED6"
#   top: "InterCameraObjectDepthPreprocessOP_BIKE6"
  measurement_stability_param {
    process_sensor_name: [
        # "center_camera_fov30",
        "center_camera_fov120",
        "rear_camera",
        "left_front_camera",
        "right_front_camera",
        "left_rear_camera",
        "right_rear_camera"
    ]
    process_label: [
        "VEHICLE",
        "PEDESTRIAN",
        "BIKE"
    ]
    reset_window_time: 2
    stable_measure_decay_rate: 0.5
    delete_window_time: 5
    var_x_threshold: 8
    var_y_threshold: 2
    direction_threshold: 15
    moving_direction_interval_time: 1
    init_shape_cov: 100
    height_standard_deviation_threshold: 0.1
    length_standard_deviation_threshold: 0.05
    width_standard_deviation_threshold: 0.1
  }
}

#noise estimator
