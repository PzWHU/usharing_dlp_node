operators {
  name: "Camera_IDBasedObjectGroupAssociatorOP_1"
  type: "IDBasedSimilarityAssociatorOP"
  top: "Camera_IDBasedObjectGroupAssociatorOP_InterLabel1"
  track_object_association_param {
    split_group_threshold: 0.0000001
    max_stability_perception_distance: 70
    object_match_param {
      process_label: [
          "VEHICLE",
          "PEDESTRIAN",
          "BIKE"
        ]
      enabled_label_checking: false
      valid_similarity_threshold: 0.2
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: CENTER_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 0.5
        }
      }
    }
  }
}

operators {
  name: "Camera_IDBasedObjectGroupAssociatorOP_2"
  type: "IDBasedSimilarityAssociatorBusOP"
  top: "Camera_IDBasedObjectGroupAssociatorOP_InterLabel1"
  track_object_association_param {
    split_group_threshold: 0.01
    var_x_threshold: 6
    var_y_threshold: 2
    delete_same_sensor_threshold: 0.90
    max_stability_perception_distance: 70
    object_match_param {
      process_label: [
          "VEHICLE",
          "VEHICLE_BUS"
        ]
      valid_similarity_threshold: 0.2
      enabled_label_checking: false
      min_tracklet_group_velocity_threshold: 1.0
      tracklet_group_merge_similarity_threshod: 0.5
      using_overlap_check: false
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: BBOX_CORNER_BHATTACHARYYA_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            lateral_distance_width_ratio: 3
        }
      }
    }
    camera_radar_split_param {
      process_label: [ "VEHICLE_BUS" ]
      camera_radar_split_threshold: 0.0005
      enabled_label_checking: false
      min_radar_number: 5
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: false
        }
      }
    }
  }
}

operators {
  name: "Camera_IDBasedObjectGroupAssociatorOP_InterLabel1"
  type: "IDBasedSimilarityAssociatorOP"
  top: "CameraTrackerObjectAssociatorBboxIouOP_1"
  top: "CameraTrackerObjectAssociatorBboxIouOP_2"
  track_object_association_param {
    split_group_threshold: 0.0000001
    max_stability_perception_distance: 70
    object_match_param {
      process_label: [
          "VEHICLE",
          "VEHICLE_BUS"
        ]
      enabled_label_checking: false
      valid_similarity_threshold: 0.2
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: CENTER_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 0.5
        }
      }
    }
  }
}

operators {
  name: "CameraTrackerObjectAssociatorBboxIouOP_1"
  type: "CameraTrackerObjectAssociatorBboxIouOP"
  top: "CameraTrackerObjectAssociatorBboxIouOP_3"
  sensor_object_preprocess_param {
    # src_sensor_name: "center_camera_fov30"
    src_sensor_names: [
        "center_camera_fov120",
        "rear_camera",
        "left_front_camera",
        "left_rear_camera",
        "right_front_camera",
        "right_rear_camera"]
    lateral_region_param: {
      min_fov_angle: 10
      max_fov_angle: 170
      min_lateral_distance: -20
      max_lateral_distance: 20
      min_longitude_distance: -30
      max_longitude_distance: 20
    }
    object_match_param {
      valid_similarity_threshold: 0.01
      lateral_distance_checking: true
      lane_checking: true
      lateral_distance_scale: 1.5
      process_label: ["VEHICLE_BUS"]
      fuzzy_similarity_threshold: 0.2
      camera_tracker_long_region_threshold: 30
      camera_tracker_lateral_region_threshold: 30
      camera_tracker_fov_region_threshold: 10
      camera_tracker_object_associator_distance_threshold: 20
      uinque_camera_checking: true
      stability_association_hit_times: 5
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: CENTER_DISTANCE_WITH_LATERAL_CHECKING
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            width_expand_ratio: 0.5
            fov_overlap_ratio_threshold: 0.5
        }
      }
    }
  }
}

operators {
  name: "CameraTrackerObjectAssociatorBboxIouOP_2"
  type: "CameraTrackerObjectAssociatorBboxIouOP"
