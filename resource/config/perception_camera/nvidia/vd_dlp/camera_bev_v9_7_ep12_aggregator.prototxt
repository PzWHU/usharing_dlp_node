##################### Camera-Radar Preprocess ############################
operators {
  name: "CameraRadarObjectPreprocessByProjectOP_1"
  type: "CameraRadarObjectPreprocessByProjectOP"
  top: "CameraRadarObjectPreprocessByLateralDistance_1"
  top: "StaticCameraRadarObjectAssociatorOP_1"
  top: "PotentialCameraRadarObjectAssociatorOP_1"
  # top: "RectifyGroupedObjectLabelOp_1"
  runnning_mode: [
    CAMERA_ONLY,
    CAMERA_RADAR,
    CAMERA_LIDAR_RADAR,
    CAMERA_LIDAR,
    LIDAR_RADAR,
    LIDAR_ONLY
  ]
  sensor_object_preprocess_param {
    src_sensor_name: "front_radar"
    src_sensor_names: [
        "front_radar",
        "front_left_radar",
        "front_right_radar",
        "rear_right_radar",
        "rear_left_radar",
        "rear_radar"
    ]
    dst_sensor_names: ["center_camera_fov120", "rear_camera"]
    car_center_name: "car_center"
    object_match_param {
      valid_similarity_threshold: 0.1
      valid_similarity_threshold_moving: 0.1
      valid_similarity_threshold_still: 0.2
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 3
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 3
            width_expand_ratio: 1.5
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            long_uncertainty_ratio: 0.08
            checking_sensor_fov_overlap: true
            fov_expand_ratio: 2
            distance_threshold: 40
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "VEHICLE" ]
      valid_similarity_threshold: 0.02
      valid_similarity_threshold_moving: 0.02
      valid_similarity_threshold_still: 0.2
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 3
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 3
            width_expand_ratio: 1.5
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            long_uncertainty_ratio: 0.08
            checking_sensor_fov_overlap: true
            fov_expand_ratio: 2
            distance_threshold: 40
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "VEHICLE_BUS" ]
      valid_similarity_threshold: 0.01
      valid_similarity_threshold_moving: 0.01
      valid_similarity_threshold_still: 0.2
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 5
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 1.5
            width_expand_ratio: 1.5
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            long_uncertainty_ratio: 0.08
            checking_sensor_fov_overlap: true
            fov_expand_ratio: 2
            distance_threshold: 50
        }
      }
    }
  }
}

operators {
  name: "PotentialCameraRadarObjectAssociatorOP_1"
  type: "PotentialCameraRadarObjectAssociatorOP"
  # top: "RectifyGroupedObjectLabelOp_1"
  top: "NaiveSensorObjectPreprocessOP_RearCameraPB"
  top: "NaiveSensorObjectPreprocessOP_LRC-VRU"
  top: "NaiveSensorObjectPreprocessOP_RRC-VRU"
  top: "NaiveSensorObjectPreprocessOP_LFC-VRU"
  top: "NaiveSensorObjectPreprocessOP_RFC-VRU"
  sensor_object_preprocess_param {
    src_sensor_name: "front_radar"
    src_sensor_names: [
        "front_radar",
        "front_left_radar",
        "front_right_radar"
    ]
    dst_sensor_names: [
        # "center_camera_fov30",
        "center_camera_fov120"
    ]
    car_center_name: "car_center"
    object_match_param {
      valid_similarity_threshold_moving: 0.001
      min_tracklet_group_velocity_threshold: 4
      camera_radar_direction_difference_threshold: 30
      camera_tracker_lateral_region_threshold: 15
      camera_tracker_long_region_threshold: 150
      camera_tracker_fov_region_threshold: 15
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 2
      }
      bev_gating_param {
        vel_dir_distance_threshold: 10
        vertical_vel_dir_distance_threshold: 2
        use_heading_direction: false
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            length_expand_ratio: 3
            width_expand_ratio: 3
            scale_factor_unit: 1
            tracklet_velocity_threshold: 3
            using_nearest_face: true
            long_uncertainty_ratio: 0.4
            checking_sensor_fov_overlap: false
            fov_expand_ratio: 2
            distance_threshold: 10
        }
      }
    }
  }
}

operators {
  name: "StaticCameraRadarObjectAssociatorOP_1"
  type: "StaticCameraRadarObjectAssociatorOP"
  # top: "RectifyGroupedObjectLabelOp_1"
  top: "NaiveSensorObjectPreprocessOP_RearCameraPB"
  top: "NaiveSensorObjectPreprocessOP_LRC-VRU"
  top: "NaiveSensorObjectPreprocessOP_RRC-VRU"
  top: "NaiveSensorObjectPreprocessOP_LFC-VRU"
  top: "NaiveSensorObjectPreprocessOP_RFC-VRU"
  sensor_object_preprocess_param {
    src_sensor_name: "front_radar"
    src_sensor_names: [
        "front_radar",
        "front_left_radar",
        "front_right_radar"
    ]
    dst_sensor_names: [
        # "center_camera_fov30",
        "center_camera_fov120"
        "rear_camera"
    ]
    car_center_name: "car_center"
    object_match_param {
      valid_similarity_threshold_moving: 0.001
      min_tracklet_group_velocity_threshold: 4
      camera_radar_direction_difference_threshold: 30
      camera_tracker_lateral_region_threshold: 15
      camera_tracker_long_region_threshold: 150
      camera_tracker_fov_region_threshold: 15
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 2
      }
      bev_gating_param {
        vel_dir_distance_threshold: 10
        vertical_vel_dir_distance_threshold: 2
        use_heading_direction: false
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            length_expand_ratio: 3
            width_expand_ratio: 2
            scale_factor_unit: 1
            tracklet_velocity_threshold: 3
            using_nearest_face: true
            long_uncertainty_ratio: 0.3
            checking_sensor_fov_overlap: true
            fov_expand_ratio: 2
            distance_threshold: 30
        }
      }
    }
  }
}

operators {
  name: "CameraRadarObjectPreprocessByLateralDistance_1"
  type: "CameraRadarObjectPreprocessByLateralDistance"
  # top: "RectifyGroupedObjectLabelOp_1"
  top: "NaiveSensorObjectPreprocessOP_RearCameraPB"
  top: "NaiveSensorObjectPreprocessOP_LRC-VRU"
  top: "NaiveSensorObjectPreprocessOP_RRC-VRU"
  top: "NaiveSensorObjectPreprocessOP_LFC-VRU"
  top: "NaiveSensorObjectPreprocessOP_RFC-VRU"
  runnning_mode: [
    CAMERA_ONLY,
    CAMERA_RADAR,
    CAMERA_LIDAR_RADAR,
    CAMERA_LIDAR,
    LIDAR_RADAR,
    LIDAR_ONLY
  ]
  radar_object_cluster_param {
    radar_project_camera_num: 1
    cluster_centroid_distance: 3
    bus_long_distance_weight: 20
    bus_lateral_distance_weight: 1.5
    vehicle_long_distance_weight: 3
    vehicle_lateral_distance_weight: 1
  }
  sensor_object_preprocess_param {
    src_sensor_name: "front_radar"
    src_sensor_names: ["rear_left_radar", "rear_right_radar", "front_left_radar", "front_right_radar", "front_radar"]
    dst_sensor_names: ["left_rear_camera", "left_front_camera", "rear_camera",
                       "right_rear_camera", "right_front_camera", "rear_camera",
                       "left_rear_camera", "left_front_camera", "center_camera_fov120",
                       "right_rear_camera", "right_front_camera", "center_camera_fov120",
                       "left_front_camera", "right_front_camera", "center_camera_fov120"]
    dst_truncated_sensor_names: ["rear_camera", "center_camera_fov120"]
    car_center_name: "car_center"
    object_match_param {
      regroup_radar_cluster: false
      valid_similarity_threshold: 0.1
      valid_similarity_threshold_moving: 0.1
      valid_similarity_threshold_still: 0.1
      valid_lateral_pixel_length: 70
      valid_lateral_length_ratio: 0.3
      near_expand_length: 2
      near_expand_witdh: 0.3
      projection_dection_bbox_x_overlap_ratio: 0.6
      projection_dection_bbox_y_overlap_ratio: 0.6
      matched_radar_distance_threshold: 55
      associated_with_group_radar_threshold: 5
      group_velocity_direction_threshold: 5
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 10
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            checking_sensor_fov_overlap: true
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "VEHICLE" ]
      valid_similarity_threshold: 0.1
      valid_similarity_threshold_moving: 0.1
      valid_similarity_threshold_still: 0.1
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 4
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            checking_sensor_fov_overlap: true
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "VEHICLE_BUS" ]
      valid_similarity_threshold: 0.1
      valid_similarity_threshold_moving: 0.1
      valid_similarity_threshold_still: 0.1
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver",
        match_capacity: 8
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            checking_sensor_fov_overlap: true
        }
      }
    }
  }
}

