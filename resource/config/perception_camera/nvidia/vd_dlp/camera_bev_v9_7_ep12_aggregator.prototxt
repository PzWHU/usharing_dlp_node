operators {
  name: "TerminalOP_final"
  type: "TerminalOP"
  top: "SetFusionObjects_PostProcess"
}

operators {
  name: "SetFusionObjects_PostProcess"
  type: "ProducerConsumerOP"
  producer_consumer_param {
    is_producer: true
    is_set_fusion_object: true
  }
}
