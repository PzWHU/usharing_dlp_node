operators {
  name: "InterCameraObjectDepthPreprocessOP_PED1"
  type: "InterCameraObjectDepthPreprocessOP"
  top: "CameraRadarObjectPreprocessByProjectOP_1"
  # top: "LidarRadarObjectPreprocessOP_1"
  # top: "LidarRadarObjectPreprocessOP_2"
  # top: "LidarRadarObjectPreprocessOP_3"
  runnning_mode: [
    CAMERA_ONLY,
    CAMERA_RADAR,
    CAMERA_LIDAR_RADAR,
    CAMERA_LIDAR,
    LIDAR_RADAR,
    LIDAR_ONLY
  ]
  sensor_object_preprocess_param {
    src_sensor_names: [
      "center_camera_fov120", 
      "rear_camera",
      "left_front_camera",
      "right_front_camera",
      "left_rear_camera",
      "right_rear_camera"]
    dst_sensor_name: ""
    object_match_param {
      process_label: ["PEDESTRIAN"]
      valid_similarity_threshold: 0.01
      var_x_threshold: 70
      var_y_threshold: 30
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            inter_camera_bbox_area_ratio_threshold: 0.8
            valid_similarity_high_threshold: 0.4
            similarity_type: INTER_CAMERA_WITH_SCALE_INVARIANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            checking_sensor_lateral_distance: true
            ped_bike_distance_threshold: 30
            lateral_distance_width_ratio: 6
        }
      }
    }
  }
}

operators {
  name: "InterCameraObjectDepthPreprocessOP_BIKE1"
  type: "InterCameraObjectDepthPreprocessOP"
  top: "CameraRadarObjectPreprocessByProjectOP_1"
  runnning_mode: [
    CAMERA_ONLY,
    CAMERA_RADAR,
    CAMERA_LIDAR_RADAR,
    CAMERA_LIDAR,
    LIDAR_RADAR,
    LIDAR_ONLY
  ]
  sensor_object_preprocess_param {
    src_sensor_names: [
      "center_camera_fov120",  
      "rear_camera",
      "left_front_camera",
      "right_front_camera",
      "left_rear_camera",
      "right_rear_camera"]
    dst_sensor_name: ""
    object_match_param {
      process_label: ["BIKE"]
      valid_similarity_threshold: 0.01
      var_x_threshold: 70
      var_y_threshold: 30
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            inter_camera_bbox_area_ratio_threshold: 0.8
            valid_similarity_high_threshold: 0.4
            similarity_type: INTER_CAMERA_WITH_SCALE_INVARIANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            checking_sensor_lateral_distance: true
            ped_bike_distance_threshold: 30
            lateral_distance_width_ratio: 6
        }
      }
    }
  }
}

