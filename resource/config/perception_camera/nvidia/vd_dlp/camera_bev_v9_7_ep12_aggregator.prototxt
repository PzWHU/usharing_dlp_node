  name: "RadarFunctionalPreprocessOP_AllRadar"
  type: "RadarFunctionalPreprocessOP"
  # top: "LidarObjectPreprocessOP_FrontLidar"
  top: "CameraObjectAttributePreprocessOP_AllCamera"
