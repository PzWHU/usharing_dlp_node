# TODO(zhangshiquan): unify radar dynamic status usage.
##! radar dynamic status will be changed in RoadsideFittingOP_1
operators {
  name: "RoadsideFittingOP_1"
  type: "RoadsideFittingOP"
  top: "ComputeMotionStatusWithVelocityOP_1"
  # top: "ComputeLidarNearestPlaneVelocity_1"
  # top: "LidarRadarVRUPreprocessOP_FrontRadar"
  roadside_param {
    enable: false
    cluster_num : 20
    cluster_iterations : 100
    ransac_iterations : 100
    ransac_sigma : 1.8
    min_curve_radius: 20
    valid_side_min_fitting_points: 8
    sensor_names: ["front_radar"]
  }
}
