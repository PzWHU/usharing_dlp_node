#measurement stbility
operators {
  name: "Radar_IDBasedObjectAssociatorOP_2"
  type: "RadarIDBasedSimilarityAssociatorBusOP"
  # top: "GeneralTrackCorrectorOP_1"
  # top: "GeneralTrackCorrectorOP_2"
  # top: "GeneralTrackCorrectorOP_3"
  top: "Radar_IDBasedObjectAssociatorOP_3"
  track_object_association_param {
    split_group_threshold: 0.00001
    var_x_threshold: 1000
    var_y_threshold: 1000
    min_velocity_threshold: 6
    min_lateral_abs_distance: 0
    max_lateral_abs_distance: 15
    min_longitude_abs_distance: 2
    max_longitude_abs_distance: 280
    object_match_param {
      process_label: [
          "VEHICLE_BUS",
          "VEHICLE",
          "BIKE"
        ]
      process_sensor_name: [
          "front_radar",
          "rear_left_radar",
          "rear_right_radar",
          "front_left_radar",
          "front_right_radar",
          "rear_radar"
        ]
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMMultiBipartiteGraphSolver"
        match_capacity: 1
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
          similarity_type: ANGLE_OF_POSITION
          similarity_usage: SIM_CASCADED
        }
      }
    }
  }
}

