operators {
  name: "CameraRadarVRUPreprocessOP_Front_Camera"
  type: "CameraRadarVRUPreprocessOP"
  top: "RoadsideFittingOP_1"
  # top: "LidarRadarVRUPreprocessOP_FrontRadar_PED"
  # top: "LidarObjectPreprocessOP_FrontLidar"
  measurement_stability_param {
    process_label: ["PEDESTRIAN", "BIKE"]
    delete_window_time: 2
    # object_hits_threshold: 7
    # potential_static_velocity_threshold: 0.5
    # potential_static_vel_dir_diff_thresh: 90
    potential_static_min_lateral_region_threshold: -20
    potential_static_max_lateral_region_threshold: 20
    potential_static_min_long_region_threshold: 1
    potential_static_max_long_region_threshold: 100
    potential_static_min_fov_region_threshold: -60
    potential_static_max_fov_region_threshold: 60
  }
  sensor_object_preprocess_param {
    src_sensor_name: "front_radar"
    src_sensor_names: ["front_radar"]
    process_label: ["PEDESTRIAN", "BIKE"]
    # dst_sensor_name: "center_camera_fov30"
    # dst_sensor_names: ["center_camera_fov30", "center_camera_fov120"]
    dst_sensor_names: ["center_camera_fov120"]
    object_match_param {
      valid_similarity_threshold: 0.7
      valid_similarity_threshold_moving: 0.001
      valid_similarity_threshold_still: 0.01
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            fov_expand_ratio: 0.3
            distance_threshold: 20
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "PEDESTRIAN", "BIKE"]
      valid_similarity_threshold_moving: 0.001
      valid_similarity_threshold_still: 0.005
      valid_similarity_threshold: 0.7
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: false
            long_uncertainty_ratio: 0.3
            checking_sensor_fov_overlap: false
            fov_expand_ratio: 2
            distance_threshold: 20
        }
      }
    }
  }
}
