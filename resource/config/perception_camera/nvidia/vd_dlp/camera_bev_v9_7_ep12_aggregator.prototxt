    #     "TraditionalnVnRnLIMMMotionCorrector"
    #   ]
    # }
    naive_assign_sensor_order : [
      "center_camera_fov120",
      # "center_camera_fov30",
      "left_front_camera",
      "right_front_camera",
      "left_rear_camera",
      "right_rear_camera",
      "rear_camera"
    ]
    motion_corrector_param {
      min_camera_update_window_time_s: 0.4
      min_velocity_to_direction: 1.5
      is_use_cov_to_update: true
      use_radar_refine_position: true
      is_use_single_radar_update: true
      lateral_zone_min_fov_angle: 15
      lateral_zone_max_fov_angle: 165
      lateral_zone_min_lateral_distance: 2
      lateral_zone_max_lateral_distance: 30
      lateral_zone_min_long_distance: -20
      lateral_zone_max_long_distance: 20
      x_velocity_threshold: 4
      y_velocity_threshold: 3
      velocity_threshold: 5
      velocity_angle_threshold: 45
      radar_moveable_threshold: 1
      still_object_threshold: 1
      camera_y_distance_threshold: 3
      x_low_distance_threshold: 4
      y_low_distance_threshold: 1.5
      velocity_x_residual_error: 4
      velocity_y_residual_error: 2
      x_high_distance_threshold: 4
      y_high_distance_threshold: 3.3
      min_filter_radar_measure: 2
      max_long_vel_meas_diff_res: 4
      max_lat_vel_meas_diff_res: 2
      radar_var_x_threshold: 3
      radar_var_y_threshold: 2
      min_radar_measure: 2
      far_distance_threshold: 80
      near_distance_threshold: 50
      near_distance_min_radar_number: 1
      medium_distance_min_radar_number: 1
      far_distance_min_radar_number: 1
      max_obejct_width: 6
      max_object_length: 20
      save_camera_number: 1
      min_hits: 10
      min_radar_measure_to_shape: 5
      max_yaw_to_shape: 6
      max_length_to_shape: 20
      camera_valid_velocity_direction: 8
      lateral_strong_stability_threshold: 0.6
      dbscan_min_neighbor_size: 1
      dbscan_long_position_theshold: 9
      dbscan_lat_position_theshold: 3
      dbscan_position_sum_theshold: 10
      min_radar_prior_refine_fov: -50
      max_radar_prior_refine_fov: 50
      rear_min_radar_prior_refine_fov: -50
      rear_max_radar_prior_refine_fov: 50
      min_yaw_rate: 10
      post_max_lateral_velocity: 1
      min_lateral_yaw_rate: 0.2
      min_stability_radar_fov: -20
      max_stability_radar_fov: 20
      stability_radar_name: [
        "front_radar",
        "rear_radar"
      ]
      label_change_lateral_distance_threshold: 1
      label_change_long_distance_threshold: 3
      min_turn_yaw_rate: 0.01
      rear_turn_yaw_rate: 0.1
      stability_radar_time_interval: 0.6
      radar_number_time_interval: 0.6
      previous_associated_radar_number: 1
      max_fitting_veloctity_hits: 10
      max_fitting_veloctity_threshold: 30
      initial_motion_hits: 3
      max_yaw_diff: 10
      sensor_switch_window: 15
      min_valocity_to_direction: 6
      interval_time_threshold: 0.1
      direction_threshold: 0.1
      lidar_lateral_different: 3.5
      lidar_yaw_rate: 0.06
      non_overtake_max_yaw_rate: 0.1
      non_overtake_min_long: 0
      non_overtake_max_long: 7
      non_overtake_min_lateral: -10
      non_overtake_max_lateral: 10
      non_overtake_min_fov: 45
      non_overtake_max_fov: 150
      occlusion_overlap_ratio_threshold: 0.01
      max_velocity_measure_direction_diff: 35
      smooth_acceleration_window: 5
      smooth_acceleration_scale: 0.7
      max_vehicle_bus_length: 30
      max_vehicle_bus_width: 3.5
      max_vehicle_bus_height: 7
      straight_head_min_long: 20
      straight_head_max_long: 50
      straight_head_min_lateral: -20
      straight_head_max_lateral: 20
      rear_straight_head_min_long: -30
      rear_straight_head_max_long: 0
      rear_straight_head_min_lateral: -2
      rear_straight_head_max_lateral: 2
      min_radar_update_track_veloctity: 2
      poject_optical_velocity_error_threshlod: 15
      poject_front_velocity_scale_threshlod: 2
      invlaid_velocity_threshold: 10000
      fov30_project_optical_error_threshold: 30
      fov120_project_optical_error_threshold: 8
      fix_velocity_long_threshold: 5
      camera_invalid_lateral_zone_min_fov_angle: 20
      camera_invalid_lateral_zone_max_fov_angle: 150
      camera_invalid_lateral_zone_min_lateral_distance: -8
      camera_invalid_lateral_zone_max_lateral_distance: 8
      camera_invalid_lateral_zone_min_long_distance: -20
      camera_invalid_lateral_zone_max_long_distance: 20
      valid_lane_info_distance: 50
      valid_lane_info_time_window_s: 20
      invalid_noise_scale: 5
      sensors_with_lane: [
      ]
      motion_direction_sensors: [
        # "center_camera_fov30",
        "center_camera_fov120",
        "rear_camera"]
      object_motion_status_distance_threshold: 50
      object_motion_status_velocity_threshold: 6
      valid_radar_lateral_position_fov_threshold: 5
      center_fvo120_valid_lateral_distance_threshold: 50
      valid_bias_interval_time: 2
      iou_threshold_to_direction: 0.6
      position_scale_threshold: 0.4
      position_base_cov_param {
        sensor_name: "center_camera_fov120"
        base_observation_covariance: 0.5
      }
      # position_base_cov_param {
      #   sensor_name: "center_camera_fov30"
      #   base_observation_covariance: 0.5
      # }
      position_base_cov_param {
        sensor_name: "left_front_camera"
        base_observation_covariance: 0.5
      }
      position_base_cov_param {
        sensor_name: "right_front_camera"
        base_observation_covariance: 0.5
      }
      position_base_cov_param {
        sensor_name: "left_rear_camera"
        base_observation_covariance: 0.5
      }
      position_base_cov_param {
        sensor_name: "right_rear_camera"
        base_observation_covariance: 0.5
      }
      position_base_cov_param {
        sensor_name: "front_lidar"
        base_observation_covariance: 0.2
      }
    }
  }
}
