#measurement stbility
operators {
  name: "ComputeMotionStatusWithVelocityOP_1"
  type: "ComputeMotionStatusWithVelocityOP"
  top: "RadarFunctionalPreprocessOP_AllRadar"
  # top: "CameraRadarVRUPreprocessOP_FOV30"
  measurement_stability_param {
    process_label: [
      "VEHICLE_BUS",
      "VEHICLE"
    ]
    delete_window_time: 2
    object_hits_threshold: 7
    potential_static_velocity_threshold: 1.5
    potential_static_vel_dir_diff_thresh: 90
    potential_static_min_lateral_region_threshold: -15
    potential_static_max_lateral_region_threshold: 15
    potential_static_min_long_region_threshold: 60
    potential_static_max_long_region_threshold: 200
    potential_static_min_fov_region_threshold: -15
    potential_static_max_fov_region_threshold: 15
  }
  sensor_object_preprocess_param {
    src_sensor_name: "front_radar"
    src_sensor_names: ["front_radar"]
    process_label: [
      "VEHICLE",
      "VEHICLE_BUS"
    ]
    # dst_sensor_name: "center_camera_fov30"
    dst_sensor_name: "center_camera_fov120"
    object_match_param {
      valid_similarity_threshold_moving: 0.001
      valid_similarity_threshold_still: 0.01
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            fov_expand_ratio: 0.3
            distance_threshold: 20
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "VEHICLE" ]
      valid_similarity_threshold_moving: 0.001
      valid_similarity_threshold_still: 0.01
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 4
            width_expand_ratio: 3
            tracklet_velocity_threshold: 1.5
            using_nearest_face: false
            long_uncertainty_ratio: 0.3
            checking_sensor_fov_overlap: false
            fov_expand_ratio: 2
            distance_threshold: 20
        }
      }
    }
    object_match_param_by_label {
      process_label: [ "VEHICLE_BUS" ]
      valid_similarity_threshold: 0.01
      valid_similarity_threshold_still: 0.01
      bipartite_graph_solver_param {
        bipartite_graph_solver_type: "KMBipartiteGraphSolver"
      }
      similarity_param {
        invalid_similarity_value: -1.0
        similarity {
            similarity_type: POINT_PLANE_DISTANCE
            similarity_usage: SIM_ADD
            similarity_weight: 1.0
            scale_factor_unit: 1
            length_expand_ratio: 2
            width_expand_ratio: 1.8
            tracklet_velocity_threshold: 1.5
            using_nearest_face: true
            long_uncertainty_ratio: 0.1
            checking_sensor_fov_overlap: true
            fov_expand_ratio: 2
            distance_threshold: 20
        }
      }
    }
  }
}

