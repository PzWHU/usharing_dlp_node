# v01 l2q256+128 mem512
num_workers: 1
module_name: "lidar_camera_bev_fusion"
is_pub_result: false
select_cameras: [
  {camera_name: "center_camera_fov30", camera_fps: 20},
  {camera_name: "center_camera_fov120", camera_fps: 20},
  {camera_name: "left_rear_camera", camera_fps: 10},
  {camera_name: "left_front_camera", camera_fps: 10},
  {camera_name: "right_rear_camera", camera_fps: 10},
  {camera_name: "right_front_camera", camera_fps: 10},
  {camera_name: "rear_camera", camera_fps: 10}
]
select_lidars {
  lidar_name: "stitching_lidar"
}
multi_cam_match_ts_th: 25000000

cuda_mutex_switch: true
wait_cuda_mutex_time_ms: 200

operators {
  name: "ImagePreprocessOP_center_camera_fov30"
  type: "ImagePreprocessOP"
  top: "CalibrationManagerOP"
  image_preprocess_param {
      camera_name: "center_camera_fov30"
      pym_slice_idx: 0
      normalize_param {
          src_image_name: "center_camera_fov30"
          dst_image_name: "center_camera_fov30_normalized_1"
          src_image_type: UINT8
          dst_image_type: FLOAT32
          b_mean: 103.53
          g_mean: 116.28
          r_mean: 123.675
          b_std: 57.375
          g_std: 57.12
          r_std: 58.395
          is_need_rgb: true
      }
      permute_param {
          src_image_name: "center_camera_fov30_normalized_1"
          dst_image_name: "center_camera_fov30_permuted_1"
          src_image_type: FLOAT32
          dst_image_type: FLOAT32
      }
  }
  execute_priority: -2
}

