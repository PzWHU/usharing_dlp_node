operators {
  name: "CalibrationManagerOP"
  type: "CalibrationManagerOP"
  top: "nullnode"
  top: "CameraAttTrasnformInputOP"
  calibration_manager_param {
    homography_valid_info {
      camera_name: "center_camera_fov30"
      is_valid_area_constraint_effective: true
      world_x_min: 3.0
      world_x_max: 20.0
      world_y_min: -10.0
      world_y_max: 10.0
      image_x_min: 0
      image_x_max: 3840
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 2160
      vanish_point_by_grid_type: "homography_solver"
      fov: 30
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
  }
  homography_valid_info {
      camera_name: "center_camera_fov120"
      is_valid_area_constraint_effective: true
      world_x_min: 3.0
      world_x_max: 20.0
      world_y_min: -10.0
      world_y_max: 10.0
      image_x_min: 0
      image_x_max: 3840
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 2160
      vanish_point_by_grid_type: "homography_solver"
      fov: 120
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
  }
    homography_valid_info {
      camera_name: "left_rear_camera"
      is_valid_area_constraint_effective: true
      world_x_min: -20.0
      world_x_max: 5.0
      world_y_min: 1.5
      world_y_max: 10.0
      image_x_min: 0
      image_x_max: 1920
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 1080
      vanish_point_by_grid_type: "homography_solver"
      fov: 120
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
    }
    homography_valid_info {
      camera_name: "left_front_camera"
      is_valid_area_constraint_effective: true
      world_x_min: -5.0
      world_x_max: 20.0
      world_y_min: 1.5
      world_y_max: 10.0
      image_x_min: 0
      image_x_max: 1920
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 1080
      vanish_point_by_grid_type: "homography_solver"
      fov: 120
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
    }
    homography_valid_info {
      camera_name: "right_rear_camera"
      is_valid_area_constraint_effective: true
      world_x_min: -20.0
      world_x_max: 5.0
      world_y_min: -10.0
      world_y_max: -1.5
      image_x_min: 0
      image_x_max: 1920
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 1080
      vanish_point_by_grid_type: "homography_solver"
      fov: 120
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
    }
    homography_valid_info {
      camera_name: "right_front_camera"
      is_valid_area_constraint_effective: true
      world_x_min: -5.0
      world_x_max: 20.0
      world_y_min: -10.0
      world_y_max: -1.5
      image_x_min: 0
      image_x_max: 1920
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 1080
      vanish_point_by_grid_type: "homography_solver"
      fov: 120
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
    }
    homography_valid_info {
      camera_name: "rear_camera"
      is_valid_area_constraint_effective: true
      world_x_min: -20.0
      world_x_max: -2.0
      world_y_min: -10.0
      world_y_max: 10.0
      image_x_min: 0
      image_x_max: 1920
      image_y_min_at_x_min: 550
      image_y_min_at_x_max: 550
      image_y_max: 1080
      vanish_point_by_grid_type: "homography_solver"
      fov: 120
      h_matrix_from_config: true
      expected_symmetric_distance: 0.02
      get_extrinsic_type: HMAT_SOLVER
      cam_gnd_height_from_extrinsic: true
      bumper_point_from_confg: false
    }
    use_online_calibrator: false
  }
  vehicle_param {
    sensor_config_folder: "/opt/senseauto_active/senseauto-vehicle-config/vehicle/A02-528"
  }
  precede_submodule: "config/x86/vd_mapqr_dlp/lidar_bev_backbone.prototxt"
  precede_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_backbone.prototxt"
  submodule_thread_type: "async"
  submodule_thread_type: "async"
}

operators {
  name: "nullnode"
  type: "NullNodeOP"
  top: "GeneralPredictorOP_bev_fusion"
  top: "GeneralInputSetupOP"
}


operators {
  name: "GeneralInputSetupOP"
  type: "GeneralInputSetupOP"
  top: "GeneralPredictorOP_bev_fusion"
  top: "SPETRPreprocessVDOP"
  top: "Laneline3dRefPreProcess"
  top: "SparseOccPreprocessOP"
  succeed_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_backbone.prototxt"
  succeed_submodule: "config/x86/vd_mapqr_dlp/lidar_bev_backbone.prototxt"
  general_input_setup_param {
    output_convert_param { # for gop
      predictor_name: "GeneralPredictorOP_lidar_branch_sim"
      net_output_name: "spatial_features_2d_lidar"
      data_input_name: "spatial_features_2d_lidar"
      data_input_shape: [1, 96, 128, 320]
    }
  }

  precede_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_pvb.prototxt"
  precede_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_road.prototxt"
  precede_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_gop.prototxt"
  submodule_thread_type: "async"
  submodule_thread_type: "async"
  submodule_thread_type: "async"
}
