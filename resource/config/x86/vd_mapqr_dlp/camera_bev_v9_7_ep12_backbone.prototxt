###### spetr backbone
operators{
  name: "SPETRPredictorOP_Backbone"
  type: "NVGeneralPredictorOP"
  top: "GeneralInputSetupOP"
  general_predictor_param {
    gpu_id: 0
    dnn_param {
      model_folder_path: "models/x86/vd_dlp/perception_0826_cityway_highway"
      model_file: "backbone.bin"
      model_weight: ""
      model_config: "parameters_backbone.json"
    }
    net_input_name: [
      "center_camera_fov30",
      "center_camera_fov120",
      "left_front_camera",
      "left_rear_camera",
      "rear_camera",
      "right_rear_camera",
      "right_front_camera"
    ]
    data_input_name: [
        "center_camera_fov30_permuted_1",
        "center_camera_fov120_permuted_1",
        "left_front_camera_permuted_1",
        "left_rear_camera_permuted_1",
        "rear_camera_permuted_1",
        "right_rear_camera_permuted_1",
        "right_front_camera_permuted_1"
    ]
    src_image_type: FLOAT32
    predictor_type: TRT_CUDA_GRAPH
  }
  execute_priority: -2
}

###### spetr GeneralInputSetupOP
operators {
  name: "GeneralInputSetupOP"
  type: "GeneralInputSetupOP"
  top: "SPETRPreprocessVDOP"
  top: "Laneline3dRefPreProcess"
  top: "SparseOccPreprocessOP"
  general_input_setup_param {
output_convert_param { # for pvb
      predictor_name: "SPETRPredictorOP_Backbone"
      net_output_name: "img_feats_0"
      data_input_name: "img_feats_0"
      data_input_shape: [1, 1792, 72, 128]
    }
    output_convert_param { # for pvb
      predictor_name: "SPETRPredictorOP_Backbone"
      net_output_name: "img_feats_1"
      data_input_name: "img_feats_1"
      data_input_shape: [1, 1792, 36, 64]
    }
    output_convert_param { # for pvb road
      predictor_name: "SPETRPredictorOP_Backbone"
      net_output_name: "img_feats_2"
      data_input_name: "img_feats_2"
      data_input_shape: [1, 1792, 18, 32]
    }
    output_convert_param { # for pvb
      predictor_name: "SPETRPredictorOP_Backbone"
      net_output_name: "img_feats_3"
      data_input_name: "img_feats_3"
      data_input_shape: [1, 1792, 9, 16]
    }
  }
  precede_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_pvb.prototxt"
  precede_submodule: "config/x86/vd_mapqr_dlp/camera_bev_v9_7_ep12_road.prototxt"
  # precede_submodule: "config/x86/vd_dlp_new/camera_bev_v9_7_ep12_occ_4in1.prototxt"
  submodule_thread_type: "async"
  submodule_thread_type: "async"
  # submodule_thread_type: "async"
}
